# Required: GitHub token for server-side PR polling
GH_TOKEN=ghp_your_github_token_here

# Required: PostgreSQL password
POSTGRES_PASSWORD=changeme

# Optional: API key for dashboard → server communication
# Generate with: docker compose exec server ax server init
AX_API_KEY=

# Optional: Port overrides
AX_PORT=8080
AX_DASHBOARD_PORT=3333
